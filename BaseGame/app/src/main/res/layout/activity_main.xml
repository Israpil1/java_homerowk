<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lavender"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/white_box"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:padding="20dp"
        android:layout_margin="40dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:layout_marginVertical="20dp"
            android:text="@string/enter_players_name" />

        <EditText
            android:id="@+id/playerOne"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="italic"
            android:inputType="text"
            android:background="@drawable/blue_border"
            android:padding="12dp"
            android:drawableStart="@drawable/ic_xicon"
            android:textColor="@color/blue"
            android:layout_marginTop="20dp"
            android:hint="@string/enter_players_one_name" />

        <EditText
            android:id="@+id/playerTwo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textStyle="italic"
            android:background="@drawable/blue_border"
            android:padding="12dp"
            android:drawableStart="@drawable/ic_oicon"
            android:textColor="@color/blue"
            android:layout_marginTop="20dp"
            android:hint="@string/enter_players_two_name" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Game Mode:"
            android:layout_marginTop="20dp"/>

        <RadioGroup
            android:id="@+id/gameModeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/pvp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Игра с человеком"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/pve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Игра с компьютером"/>
        </RadioGroup>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выберите сложность:"
            android:layout_marginTop="10dp"
            android:textColor="@color/black"/>

        <Spinner
            android:id="@+id/difficultySpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/blue_border"
            android:padding="10dp" />
        <Button
            android:id="@+id/startGameButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="20dp"
            android:textSize="18sp"
            app:cornerRadius="20dp"
            android:text="@string/start_game" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>